# =============================================================================
# AGI Workforce Web App — Environment Variables
# Copy this file to .env.local and fill in the values for local development.
# For production, set these as environment variables in your hosting provider
# (e.g. Vercel project settings).
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase — REQUIRED
# Find these in your Supabase project settings > API.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Alternative Supabase URL key (used in some routes as fallback for NEXT_PUBLIC_SUPABASE_URL)
# SUPABASE_URL=https://your-project-id.supabase.co

# Alternative anon key (used in some routes as fallback for NEXT_PUBLIC_SUPABASE_ANON_KEY)
# SUPABASE_ANON_KEY=your-anon-key


# -----------------------------------------------------------------------------
# Stripe — REQUIRED for billing/payments
# Find these in your Stripe dashboard > Developers > API keys.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# Publishable key (safe to expose to browser) — used by checkout UI
# Obtain at https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key

# Stripe Price IDs — create products in the Stripe dashboard and paste the
# price IDs here. Both monthly and annual variants are required per tier.
STRIPE_PRICE_HOBBY_MONTHLY=price_hobby_monthly
STRIPE_PRICE_HOBBY_YEARLY=price_hobby_yearly
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly
STRIPE_PRICE_PRO_YEARLY=price_pro_yearly
STRIPE_PRICE_MAX_MONTHLY=price_max_monthly
STRIPE_PRICE_MAX_YEARLY=price_max_yearly
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_enterprise_monthly
STRIPE_PRICE_ENTERPRISE_YEARLY=price_enterprise_yearly

# Optional: JSON string of overrides for price IDs (comma-separated key:value pairs)
# PRICE_ID_OVERRIDES=custom_price_id_1,tier:custom_price_id_2


# -----------------------------------------------------------------------------
# Rate Limiting — REQUIRED in production (Upstash Redis)
# Create a Redis database at https://console.upstash.com and copy the REST URL
# and token from the database details page. Without this, rate limiting is
# disabled and all API endpoints are unprotected against abuse.
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token


# -----------------------------------------------------------------------------
# Image Generation — at least ONE of the following is required to enable
# the image generation API (/api/media/image/generate). The server picks the
# first key that is set (Google > OpenAI > Stability).
# -----------------------------------------------------------------------------

# Google Imagen 4 (also used for Google Veo video generation below)
# Obtain at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key

# OpenAI DALL-E 3
# Obtain at https://platform.openai.com/api-keys
# Also required for audio transcription (/api/llm/v1/audio/transcriptions)
OPENAI_API_KEY=your-openai-api-key

# Stability AI Stable Image Core (v2beta)
# Obtain at https://platform.stability.ai/account/keys
STABILITY_API_KEY=your-stability-api-key


# -----------------------------------------------------------------------------
# Video Generation — at least ONE of the following is required to enable
# the video generation API (/api/media/video/generate).
# The server prefers Runway when both keys are set.
# -----------------------------------------------------------------------------

# Runway Gen4 Turbo (text-to-video)
# Obtain at https://app.runwayml.com/account/api-keys
RUNWAY_API_KEY=your-runway-api-key

# Google Veo3 (text-to-video via Generative Language API)
# Uses GOOGLE_API_KEY above — no separate key needed.


# -----------------------------------------------------------------------------
# LLM Providers — used by /api/llm/v1/chat/completions and related routes.
# At least one provider key is required for AI chat features. The managed
# cloud provider in the Rust desktop backend uses its own key management;
# these keys power the web-side LLM proxy.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key
# OPENAI_API_KEY=  (already listed above under Image Generation)
# GOOGLE_API_KEY=  (already listed above under Image Generation)
XAI_API_KEY=your-xai-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
QWEN_API_KEY=your-qwen-api-key
MOONSHOT_API_KEY=your-moonshot-api-key
PERPLEXITY_API_KEY=your-perplexity-api-key
ZHIPU_API_KEY=your-zhipu-api-key

# Optional: Override base URLs for LLM providers (useful for proxies or on-prem deployments)
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# OPENAI_BASE_URL=https://api.openai.com
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com
# XAI_BASE_URL=https://api.x.ai
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# QWEN_BASE_URL=https://api.mulerouter.ai
# MOONSHOT_BASE_URL=https://api.moonshot.cn
# PERPLEXITY_BASE_URL=https://api.perplexity.ai
# ZHIPU_BASE_URL=https://open.bigmodel.cn


# -----------------------------------------------------------------------------
# Application URLs — REQUIRED in production
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Used by some chat routes as a fallback base URL for internal API calls
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# API gateway base URL for web → backend service calls.
# Defaults to http://localhost:3001 in development if unset.
# In production this should point to your deployed api-gateway service.
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# MCP client base URL — used by the MCP client to connect to the API gateway.
# Defaults to http://localhost:3000 if unset.
# NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:3000

# Application metadata shown in the settings UI and about page.
# NEXT_PUBLIC_APP_VERSION is set automatically by the build pipeline;
# override only if you need a manual version label.
# NEXT_PUBLIC_APP_VERSION=1.0.0
# NEXT_PUBLIC_BUILD_NUMBER=1

# Set to "true" to enable demo mode (image/video generation uses mock responses
# instead of calling real API keys). Useful for staging / sales demos.
# NEXT_PUBLIC_DEMO_MODE=false


# -----------------------------------------------------------------------------
# Security — REQUIRED in production
# -----------------------------------------------------------------------------

# CSRF protection secret — generate with: openssl rand -hex 32
CSRF_SECRET=your-csrf-secret-at-least-32-chars

# Server-side encryption key for SecurityManager (minimum 32 characters).
# Used for encrypting tokens and sensitive data server-side.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-encryption-key-at-least-32-chars

# Device token encryption key — 32-byte hex string (64 hex chars)
# Generate with: openssl rand -hex 32
# Falls back to SUPABASE_SERVICE_ROLE_KEY if not set (less secure).
DEVICE_TOKEN_ENCRYPTION_KEY=your-64-hex-char-key

# TOTP encryption key — used to encrypt TOTP secrets stored in the database
# for two-factor authentication (authenticator app flows).
# Generate with: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=your-totp-encryption-key-hex-32-bytes

# Desktop token secret — fallback key used by /api/auth/desktop-token when
# TOTP_ENCRYPTION_KEY is not set. Generate with: openssl rand -hex 32
# DESKTOP_TOKEN_SECRET=your-desktop-token-secret

# CORS — comma-separated list of allowed origins. In development,
# localhost ports are allowed automatically.
# ALLOWED_ORIGINS=https://your-domain.com,https://other-domain.com


# -----------------------------------------------------------------------------
# Enterprise — optional unless using SSO or SCIM directory sync
# -----------------------------------------------------------------------------

# WorkOS webhook secret for SCIM/directory sync (/api/webhooks/directory-sync)
# WORKOS_WEBHOOK_SECRET=your-workos-webhook-secret

# SCIM group name overrides (comma-separated). Defaults shown.
# SCIM_ADMIN_GROUP_NAMES=Admins
# SCIM_VIEWER_GROUP_NAMES=Viewers,ReadOnly


# -----------------------------------------------------------------------------
# Cron Jobs — optional
# Set on Vercel to secure the /api/cron/* endpoints so only Vercel Cron can
# call them. Leave unset in development.
# -----------------------------------------------------------------------------
# CRON_SECRET=your-cron-secret


# -----------------------------------------------------------------------------
# GitHub — optional, for desktop app update/release routes
# Unauthenticated GitHub API requests are rate-limited to 60/hour. Set a
# personal access token (no scopes needed for public repos) to raise the limit.
# -----------------------------------------------------------------------------
# GITHUB_TOKEN=ghp_your-github-personal-access-token
# DESKTOP_GITHUB_OWNER=your-github-org-or-username
# DESKTOP_GITHUB_REPO=your-desktop-release-repo

# Desktop download URL overrides (default to /downloads/* paths)
# NEXT_PUBLIC_DOWNLOAD_URL_MAC=https://your-cdn.com/agiworkforce.dmg
# NEXT_PUBLIC_DOWNLOAD_URL_WINDOWS=https://your-cdn.com/agi-workforce-win.exe
# NEXT_PUBLIC_DOWNLOAD_URL_LINUX=https://your-cdn.com/agi-workforce-linux.AppImage


# -----------------------------------------------------------------------------
# GitHub App Integration — optional, for GitHub App webhooks and code review
# Create a GitHub App at https://github.com/settings/apps and configure these.
# Required for /api/github/webhook and GitHub-powered code review features.
# -----------------------------------------------------------------------------
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY_BASE64=base64-encoded-pem-private-key
# GITHUB_WEBHOOK_SECRET=your-github-app-webhook-secret
# GITHUB_TOKEN_ENCRYPTION_KEY=your-github-token-encryption-key
# GITHUB_BOT_LOGIN=agi-workforce[bot]


# -----------------------------------------------------------------------------
# Analytics — optional
# Set to a GA4 Measurement ID (format: G-XXXXXXXXXX) to enable Google Analytics.
# The script is loaded with strategy="afterInteractive" (non-blocking) and only
# when this variable is present. Leave unset to disable analytics entirely.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX


# -----------------------------------------------------------------------------
# Logging & Observability — optional
# -----------------------------------------------------------------------------

# Log level: trace | debug | info | warn | error (default: info in production)
# LOG_LEVEL=info

# LLM SLO thresholds in milliseconds (time-to-first-token)
# LLM_TTFT_SLO_TARGET_MS=2500
# LLM_TTFT_SLO_BREACH_MS=5000

# Optional webhook URL for monitoring alerts (e.g. Slack incoming webhook).
# When set, SLO breaches and critical errors are posted to this URL.
# NEXT_PUBLIC_MONITORING_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
