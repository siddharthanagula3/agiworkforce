{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && corepack enable && corepack prepare pnpm@9.15.3 --activate && VITE_BUILD_TARGET=web pnpm --filter @agiworkforce/desktop exec vite build --outDir dist-web --base /chat/ && cp -r apps/desktop/dist-web apps/web/public/chat && pnpm --filter web build",
  "devCommand": "pnpm dev",
  "installCommand": "cd ../.. && corepack enable && corepack prepare pnpm@9.15.3 --activate && pnpm install",
  "framework": "nextjs",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "rewrites": [
    {
      "source": "/v1/chat/completions",
      "destination": "/api/llm/v1/chat/completions",
      "has": [{ "type": "host", "value": "api.agiworkforce.com" }]
    },
    {
      "source": "/v1/models",
      "destination": "/api/llm/v1/models",
      "has": [{ "type": "host", "value": "api.agiworkforce.com" }]
    },
    {
      "source": "/v1/credits/balance",
      "destination": "/api/llm/v1/credits/balance",
      "has": [{ "type": "host", "value": "api.agiworkforce.com" }]
    },
    {
      "source": "/v1/audio/transcriptions",
      "destination": "/api/llm/v1/audio/transcriptions",
      "has": [{ "type": "host", "value": "api.agiworkforce.com" }]
    },
    {
      "source": "/health",
      "destination": "/api/health",
      "has": [{ "type": "host", "value": "api.agiworkforce.com" }]
    },
    {
      "source": "/chat/:path*",
      "destination": "/chat/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/reset-credits",
      "schedule": "0 0 * * *"
    }
  ]
}
