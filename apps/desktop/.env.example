# AGI Workforce Desktop — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git — it is listed in .gitignore.
#
# Only VITE_* variables are exposed to the browser/renderer process.
# Variables without the VITE_ prefix are available only during the Vite
# build process (e.g. in vite.config.ts) and are NOT accessible at runtime.

# =============================================================================
# Supabase Configuration  (REQUIRED)
# Get these values from your Supabase project dashboard: Settings → API
# =============================================================================

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous/public key (safe to expose in the frontend)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================================
# Backend / API
# =============================================================================

# Base URL for the AGI Workforce API gateway.
# Defaults to https://www.agiworkforce.com if not set.
VITE_API_BASE_URL=https://www.agiworkforce.com

# URL of the web app (used for redirect/callback links, e.g. OAuth flows).
# Defaults to https://www.agiworkforce.com if not set.
VITE_WEB_APP_URL=https://www.agiworkforce.com

# HTTP URL of the WebRTC signaling server.
# Defaults to http://localhost:4000 if not set.
VITE_SIGNALING_HTTP_URL=http://localhost:4000

# =============================================================================
# Observability / Error Tracking  (optional)
# =============================================================================

# Sentry DSN for error reporting. Leave blank or omit to disable Sentry.
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Application version string injected into error reports.
# Normally derived from package.json at build time; override here if needed.
# VITE_APP_VERSION=1.0.0

# =============================================================================
# Status Page  (optional)
# =============================================================================

# URL polled by the StatusBanner component to display service health.
# Leave blank to disable the status banner.
# VITE_STATUS_URL=https://status.agiworkforce.com

# =============================================================================
# Development / Testing Overrides  (dev mode only — never set in production)
# =============================================================================

# When set, these values inject a fake authenticated account in development
# so you can test subscription-gated features without a real Supabase session.
# These are read only when import.meta.env.DEV === true.
# VITE_DEV_ACCOUNT_EMAIL=dev@example.com
# VITE_DEV_ACCOUNT_NAME=Dev User
# VITE_DEV_ACCOUNT_PLAN=pro

# Override the local dev server port used by Vite (tauri dev).
# Defaults to the port defined in vite.config.ts.
# VITE_DEV_PORT=1420
