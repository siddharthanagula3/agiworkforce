# Development Server
VITE_DEV_PORT=5173
TAURI_DEV_HOST=

# Tauri Configuration
TAURI_PLATFORM=
TAURI_DEBUG=

# Managed Cloud API (Vercel proxy / AGI backend)
VITE_API_BASE_URL=https://api.agiworkforce.com
AGI_API_URL=https://api.agiworkforce.com

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Feature Flags
VITE_ENABLE_OLLAMA=true
VITE_ENABLE_TELEMETRY=false

# Logging
RUST_LOG=info
RUST_BACKTRACE=1

# Sentry Error Tracking
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_SENTRY_ENVIRONMENT=production
VITE_APP_VERSION=0.1.0

# Stripe (Optional - for Desktop billing)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Apple Notarization (macOS only - required for distribution)
APPLE_ID=your-apple-id@email.com
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_PASSWORD=xxxx-xxxx-xxxx-xxxx
