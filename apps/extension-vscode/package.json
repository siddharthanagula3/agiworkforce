{
  "name": "agi-workforce",
  "displayName": "AGI Workforce",
  "description": "Multi-provider AI coding assistant — 10+ providers (GPT, Claude, Gemini, and more) in VS Code",
  "version": "0.3.0",
  "publisher": "agiworkforce",
  "license": "PROPRIETARY",
  "repository": {
    "type": "git",
    "url": "https://github.com/agiworkforce/agiworkforce"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "preview": true,
  "pricing": "Free",
  "galleryBanner": {
    "color": "#0f0f0f",
    "theme": "dark"
  },
  "qna": "marketplace",
  "categories": [
    "AI",
    "Chat",
    "Machine Learning",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "llm",
    "chat",
    "copilot",
    "assistant",
    "coding",
    "agent",
    "gpt",
    "claude",
    "gemini"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onChatParticipant:agiworkforce.agi",
    "onView:agi-workforce.sidebar"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "API endpoint, gateway URL, CLI path, and system prompt settings cannot be overridden by workspace settings in untrusted workspaces. Agent mode file writes are disabled until the workspace is trusted.",
      "restrictedConfigurations": [
        "agiWorkforce.apiEndpoint",
        "agiWorkforce.gatewayUrl",
        "agiWorkforce.cliPath",
        "agiWorkforce.systemPrompt",
        "agiWorkforce.agent.autoApply",
        "agiWorkforce.autoApplyFixes",
        "agiWorkforce.telemetryEndpoint",
        "agiWorkforce.tier"
      ]
    }
  },
  "main": "./out/extension.js",
  "icon": "media/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "agi-workforce.chat",
        "title": "AGI Workforce: Open Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "agi-workforce.agentMode",
        "title": "AGI Workforce: Agent Mode",
        "icon": "$(robot)"
      },
      {
        "command": "agi-workforce.explain",
        "title": "AGI Workforce: Explain Selection",
        "icon": "$(info)"
      },
      {
        "command": "agi-workforce.fix",
        "title": "AGI Workforce: Fix Issue",
        "icon": "$(wrench)"
      },
      {
        "command": "agi-workforce.refactor",
        "title": "AGI Workforce: Refactor Code",
        "icon": "$(symbol-class)"
      },
      {
        "command": "agi-workforce.generateTests",
        "title": "AGI Workforce: Generate Tests",
        "icon": "$(beaker)"
      },
      {
        "command": "agi-workforce.setApiKey",
        "title": "AGI Workforce: Set API Key",
        "icon": "$(key)"
      },
      {
        "command": "agi-workforce.clearApiKey",
        "title": "AGI Workforce: Clear API Key",
        "icon": "$(trash)"
      },
      {
        "command": "agi-workforce.setSupabaseJwt",
        "title": "AGI Workforce: Set Supabase JWT",
        "icon": "$(key)"
      },
      {
        "command": "agi-workforce.clearSupabaseJwt",
        "title": "AGI Workforce: Clear Supabase JWT",
        "icon": "$(trash)"
      },
      {
        "command": "agi-workforce.selectModel",
        "title": "AGI Workforce: Select Model",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "agi-workforce.openConversation",
        "title": "AGI Workforce: Open Conversation",
        "icon": "$(comment)"
      },
      {
        "command": "agi-workforce.deleteConversation",
        "title": "AGI Workforce: Delete Conversation",
        "icon": "$(trash)"
      },
      {
        "command": "agi-workforce.refreshConversations",
        "title": "AGI Workforce: Refresh Conversations",
        "icon": "$(refresh)"
      },
      {
        "command": "agi-workforce.sendToDesktop",
        "title": "AGI Workforce: Send Code to Desktop Agent",
        "icon": "$(export)"
      },
      {
        "command": "agi-workforce.syncContextToDesktop",
        "title": "AGI Workforce: Sync Workspace Context to Desktop",
        "icon": "$(sync)"
      },
      {
        "command": "agi-workforce.triggerAgentAction",
        "title": "AGI Workforce: Trigger Agent Action on Desktop",
        "icon": "$(play)"
      },
      {
        "command": "agi-workforce.createCheckpoint",
        "title": "AGI Workforce: Create Checkpoint",
        "icon": "$(bookmark)"
      },
      {
        "command": "agi-workforce.restoreCheckpoint",
        "title": "AGI Workforce: Restore Checkpoint",
        "icon": "$(history)"
      },
      {
        "command": "agi-workforce.listCheckpoints",
        "title": "AGI Workforce: List Checkpoints",
        "icon": "$(list-unordered)"
      },
      {
        "command": "agi.git.status",
        "title": "AGI: Git Status",
        "icon": "$(source-control)"
      },
      {
        "command": "agi.git.diff",
        "title": "AGI: Git Diff",
        "icon": "$(diff)"
      },
      {
        "command": "agi.git.commit",
        "title": "AGI: Git Commit",
        "icon": "$(git-commit)"
      },
      {
        "command": "agi.test.run",
        "title": "AGI: Run Tests",
        "icon": "$(beaker)"
      },
      {
        "command": "agi-workforce.resetTokenCounter",
        "title": "AGI Workforce: Reset Token Counter",
        "icon": "$(clear-all)"
      },
      {
        "command": "agi-workforce.docs",
        "title": "AGI Workforce: Generate Docs",
        "icon": "$(book)"
      },
      {
        "command": "agi-workforce.codeReview",
        "title": "AGI Workforce: Code Review",
        "icon": "$(eye)"
      },
      {
        "command": "agi-workforce.sendFeedback",
        "title": "AGI Workforce: Send Feedback",
        "icon": "$(feedback)"
      },
      {
        "command": "agi-workforce.runCommand",
        "title": "AGI Workforce: Run Terminal Command",
        "icon": "$(terminal)"
      },
      {
        "command": "agi-workforce.explainTerminal",
        "title": "AGI Workforce: Explain Terminal Output",
        "icon": "$(output)"
      },
      {
        "command": "agi-workforce.suggestCommand",
        "title": "AGI Workforce: Suggest Terminal Command",
        "icon": "$(wand)"
      },
      {
        "command": "agi-workforce.explainError",
        "title": "AGI Workforce: Explain Error",
        "icon": "$(error)"
      },
      {
        "command": "agi-workforce.askAboutCode",
        "title": "AGI Workforce: Ask About Code",
        "icon": "$(question)"
      },
      {
        "command": "agi-workforce.newConversation",
        "title": "AGI Workforce: New Conversation",
        "icon": "$(add)"
      },
      {
        "command": "agi-workforce.modelDashboard",
        "title": "AGI Workforce: Model Dashboard",
        "icon": "$(graph)"
      },
      {
        "command": "agi-workforce.showTokenBreakdown",
        "title": "AGI Workforce: Show Token Breakdown",
        "icon": "$(pulse)"
      },
      {
        "command": "agi-workforce.acceptDiff",
        "title": "AGI Workforce: Accept Diff",
        "icon": "$(check)"
      },
      {
        "command": "agi-workforce.rejectDiff",
        "title": "AGI Workforce: Reject Diff",
        "icon": "$(close)"
      },
      {
        "command": "agi-workforce.acceptAllDiffs",
        "title": "AGI Workforce: Accept All Diffs in File",
        "icon": "$(check-all)"
      },
      {
        "command": "agi-workforce.rejectAllDiffs",
        "title": "AGI Workforce: Reject All Diffs in File",
        "icon": "$(close-all)"
      },
      {
        "command": "agi-workforce.acceptCurrentDiff",
        "title": "AGI Workforce: Accept Current Diff",
        "icon": "$(check)"
      },
      {
        "command": "agi-workforce.rejectCurrentDiff",
        "title": "AGI Workforce: Reject Current Diff",
        "icon": "$(close)"
      },
      {
        "command": "agi-workforce.acceptAllDiffsGlobal",
        "title": "AGI Workforce: Accept All Diffs (All Files)",
        "icon": "$(check-all)"
      },
      {
        "command": "agi-workforce.rejectAllDiffsGlobal",
        "title": "AGI Workforce: Reject All Diffs (All Files)",
        "icon": "$(close-all)"
      },
      {
        "command": "agi-workforce.acceptBatch",
        "title": "AGI Workforce: Accept Entire Patch Batch",
        "icon": "$(checklist)"
      },
      {
        "command": "agi-workforce.rejectBatch",
        "title": "AGI Workforce: Reject Entire Patch Batch",
        "icon": "$(trash)"
      },
      {
        "command": "agi-workforce.showOriginalContext",
        "title": "AGI Workforce: Show Original Context (Patch Expected vs Actual)",
        "icon": "$(diff)"
      },
      {
        "command": "agi-workforce.showPatchLogs",
        "title": "AGI Workforce: Show Patch Logs",
        "icon": "$(output)"
      },
      {
        "command": "agi-workforce.bridgeReconnect",
        "title": "AGI Workforce: Reconnect Desktop Bridge",
        "icon": "$(debug-restart)"
      },
      {
        "command": "agi-workforce.addToContext",
        "title": "AGI Workforce: Add File to Context",
        "icon": "$(pin)"
      },
      {
        "command": "agi-workforce.removeFromContext",
        "title": "AGI Workforce: Remove from Context",
        "icon": "$(pinned-dirty)"
      },
      {
        "command": "agi-workforce.clearContext",
        "title": "AGI Workforce: Clear Context",
        "icon": "$(clear-all)"
      },
      {
        "command": "agi-workforce.refreshContext",
        "title": "AGI Workforce: Refresh Context",
        "icon": "$(refresh)"
      },
      {
        "command": "agi-workforce.openActionSheet",
        "title": "AGI Workforce: Open Actions",
        "icon": "$(menu)"
      },
      {
        "command": "agi-workforce.rewindLast",
        "title": "AGI Workforce: Rewind Last",
        "icon": "$(history)"
      },
      {
        "command": "agi-workforce.showSubsystemHealth",
        "title": "AGI: Show Subsystem Health",
        "category": "AGI"
      },
      {
        "command": "agi-workforce.showTierStatus",
        "title": "AGI Workforce: Show Tier Status",
        "icon": "$(account)"
      }
    ],
    "chatParticipants": [
      {
        "id": "agiworkforce.agi",
        "name": "agi",
        "fullName": "AGI Workforce",
        "description": "Multi-provider AI coding assistant — 10+ providers (GPT, Claude, Gemini, and more)",
        "isSticky": true,
        "commands": [
          {
            "name": "explain",
            "description": "Explain the selected code or current file"
          },
          {
            "name": "fix",
            "description": "Find and fix bugs or issues in the selected code"
          },
          {
            "name": "refactor",
            "description": "Suggest refactoring improvements for the selected code"
          },
          {
            "name": "tests",
            "description": "Generate unit tests for the selected code"
          },
          {
            "name": "docs",
            "description": "Generate documentation comments for the selected code"
          },
          {
            "name": "model",
            "description": "Switch the active LLM model"
          }
        ],
        "disambiguation": [
          {
            "category": "coding",
            "description": "Questions about writing, understanding, debugging, or improving code",
            "examples": [
              "Explain this function to me",
              "Why is this code throwing an error?",
              "How can I optimize this algorithm?",
              "Write unit tests for this class"
            ]
          },
          {
            "category": "architecture",
            "description": "Questions about software design, architecture, and best practices",
            "examples": [
              "What design pattern should I use here?",
              "How should I structure this module?",
              "What are the tradeoffs between these approaches?"
            ]
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agi-workforce-sidebar",
          "title": "AGI Workforce",
          "icon": "media/icon-sidebar.svg"
        }
      ]
    },
    "views": {
      "agi-workforce-sidebar": [
        {
          "type": "webview",
          "id": "agi-workforce.sidebar",
          "name": "AGI Workforce",
          "contextualTitle": "AGI Workforce"
        },
        {
          "type": "tree",
          "id": "agi-workforce.conversations",
          "name": "History",
          "contextualTitle": "Conversation History"
        },
        {
          "type": "tree",
          "id": "agi-workforce.contextPanel",
          "name": "Context Files",
          "contextualTitle": "AI Context",
          "visibility": "collapsed"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "agi-workforce.openConversation",
          "when": "view == agi-workforce.conversations && viewItem == conversation",
          "group": "inline@1"
        },
        {
          "command": "agi-workforce.deleteConversation",
          "when": "view == agi-workforce.conversations && viewItem == conversation",
          "group": "inline@2"
        },
        {
          "command": "agi-workforce.removeFromContext",
          "when": "view == agi-workforce.contextPanel && viewItem == pinnedFile",
          "group": "inline"
        }
      ],
      "view/title": [
        {
          "command": "agi-workforce.refreshConversations",
          "when": "view == agi-workforce.conversations",
          "group": "navigation"
        },
        {
          "command": "agi-workforce.refreshContext",
          "when": "view == agi-workforce.contextPanel",
          "group": "navigation@1"
        },
        {
          "command": "agi-workforce.clearContext",
          "when": "view == agi-workforce.contextPanel",
          "group": "navigation@2"
        }
      ],
      "editor/context": [
        {
          "command": "agi-workforce.explain",
          "when": "editorHasSelection",
          "group": "agi-workforce@1"
        },
        {
          "command": "agi-workforce.fix",
          "when": "editorHasSelection",
          "group": "agi-workforce@2"
        },
        {
          "command": "agi-workforce.refactor",
          "when": "editorHasSelection",
          "group": "agi-workforce@3"
        },
        {
          "command": "agi-workforce.generateTests",
          "when": "editorHasSelection",
          "group": "agi-workforce@4"
        },
        {
          "command": "agi-workforce.docs",
          "when": "editorHasSelection",
          "group": "agi-workforce@5"
        },
        {
          "command": "agi-workforce.codeReview",
          "when": "editorHasSelection",
          "group": "agi-workforce@6"
        },
        {
          "command": "agi-workforce.askAboutCode",
          "group": "agi-workforce@7"
        },
        {
          "command": "agi-workforce.explainError",
          "group": "agi-workforce@8"
        },
        {
          "command": "agi-workforce.addToContext",
          "group": "agi-workforce@9"
        }
      ],
      "commandPalette": [
        {
          "command": "agi-workforce.explain",
          "when": "editorHasSelection"
        },
        {
          "command": "agi-workforce.fix",
          "when": "editorTextFocus"
        },
        {
          "command": "agi-workforce.docs",
          "when": "editorHasSelection"
        },
        {
          "command": "agi-workforce.codeReview",
          "when": "editorTextFocus"
        }
      ]
    },
    "configuration": {
      "title": "AGI Workforce",
      "properties": {
        "agiWorkforce.apiEndpoint": {
          "type": "string",
          "default": "https://agiworkforce.com/api/llm/v1",
          "description": "AGI Workforce API endpoint base URL"
        },
        "agiWorkforce.model": {
          "type": "string",
          "default": "auto-balanced",
          "description": "Default LLM model. Run 'AGI Workforce: Select Model' (cmd+shift+m) to pick from currently available providers."
        },
        "agiWorkforce.streamingEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable streaming responses from AGI Workforce API"
        },
        "agiWorkforce.contextLines": {
          "type": "number",
          "default": 50,
          "minimum": 0,
          "maximum": 500,
          "description": "Number of surrounding lines to include as context"
        },
        "agiWorkforce.fallbackToVscodeLm": {
          "type": "boolean",
          "default": true,
          "description": "Fall back to VS Code built-in Language Model API if AGI Workforce API is unavailable"
        },
        "agiWorkforce.telemetryEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Send anonymous usage telemetry to help improve AGI Workforce"
        },
        "agiWorkforce.hoverEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Show AGI Workforce quick actions on hover over identifiers"
        },
        "agiWorkforce.codeLensEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show 'Ask AI', 'Tests', 'Docs' lenses above functions and classes"
        },
        "agiWorkforce.autoApplyFixes": {
          "type": "boolean",
          "default": false,
          "description": "Automatically apply AI-suggested fixes without showing a diff"
        },
        "agiWorkforce.inlineCompletions.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable ghost-text inline completions (requires API key)"
        },
        "agiWorkforce.inlineCompletions.debounceMs": {
          "type": "number",
          "default": 300,
          "minimum": 50,
          "maximum": 2000,
          "description": "Debounce delay in milliseconds before requesting inline completions (default: 300ms)"
        },
        "agiWorkforce.inlineCompletions.maxLength": {
          "type": "number",
          "default": 500,
          "minimum": 50,
          "maximum": 5000,
          "description": "Maximum character length for inline completion suggestions (default: 500)"
        },
        "agiWorkforce.agent.planMode": {
          "type": "boolean",
          "default": false,
          "description": "Deprecated — use agiWorkforce.agent.mode instead. When true, maps to agent.mode = 'plan'."
        },
        "agiWorkforce.agent.mode": {
          "type": "string",
          "enum": [
            "ask",
            "auto",
            "plan",
            "bypass"
          ],
          "default": "auto",
          "description": "Default agent mode for new conversations. 'ask' confirms every edit, 'auto' edits without confirmation, 'plan' proposes a plan before any edits, 'bypass' skips all approval prompts."
        },
        "agiWorkforce.agent.effort": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "max"
          ],
          "default": "medium",
          "description": "Reasoning effort for providers that support it (Anthropic, OpenAI, Google). Ignored when provider does not support an explicit effort axis."
        },
        "agiWorkforce.agent.maxIterations": {
          "type": "number",
          "default": 25,
          "minimum": 1,
          "maximum": 200,
          "description": "Maximum number of autonomous continuation iterations per agent session before prompting for confirmation (default: 25)"
        },
        "agiWorkforce.mcp.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Model Context Protocol (MCP) tool integrations"
        },
        "agiWorkforce.desktopBridge.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Connect to AGI Workforce desktop app for extended agent capabilities"
        },
        "agiWorkforce.desktopBridge.port": {
          "type": "number",
          "default": 8787,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Local port for AGI Workforce desktop bridge connection"
        },
        "agiWorkforce.telemetryEndpoint": {
          "type": "string",
          "default": "https://telemetry.agiworkforce.com/v1/events",
          "description": "Endpoint URL for sending anonymous telemetry events"
        },
        "agiWorkforce.useProviderStream": {
          "type": "boolean",
          "default": false,
          "description": "Route chat through the new /api/v1/providers/:id/stream pipeline instead of the legacy AGI Workforce LLM proxy. Requires a Supabase JWT (run \"AGI Workforce: Set Supabase JWT\")."
        },
        "agiWorkforce.gatewayUrl": {
          "type": "string",
          "default": "https://api.agiworkforce.com",
          "description": "Base URL of the AGI Workforce gateway used by the provider-stream path. Override for self-hosted / regional gateways."
        },
        "agiWorkforce.providerStreamProvider": {
          "type": "string",
          "enum": [
            "auto",
            "anthropic",
            "openai",
            "google",
            "ollama",
            "ollama-cloud",
            "xai",
            "deepseek",
            "perplexity",
            "qwen",
            "moonshot",
            "zhipu",
            "lmstudio",
            "custom"
          ],
          "default": "auto",
          "markdownDescription": "Provider used on the provider-stream path. `auto` infers from the model id prefix (claude-* → anthropic, gpt-* → openai, gemini-* → google, otherwise → ollama). For the full list of supported providers, see the [docs](https://agiworkforce.com/docs/providers)."
        },
        "agiWorkforce.currentTier": {
          "type": "string",
          "default": "unknown",
          "readOnly": true,
          "description": "Current subscription tier (read-only, populated on activation). Run 'AGI Workforce: Show Tier Status' to see full usage details or visit agiworkforce.com/pricing to upgrade."
        },
        "agiWorkforce.tier": {
          "type": "string",
          "enum": [
            "local",
            "byok",
            "hobby",
            "pro",
            "pro_plus",
            "max"
          ],
          "enumDescriptions": [
            "Local-only mode — Ollama / LMStudio, no cloud, no multi-provider switch.",
            "Bring-your-own-key — free, single-provider per session (default).",
            "Hobby managed cloud — limited credits, single-provider per session.",
            "Pro managed cloud — higher limits, single-provider per session.",
            "Pro+ ($49.99/mo) — unlocks multi-provider in-thread switching.",
            "Max — highest limits, all features."
          ],
          "default": "byok",
          "markdownDescription": "Subscription tier override for the VS Code extension. When set to any value other than `byok`, this overrides the live tier fetched from the desktop bridge or API (useful for testing). Leave at `byok` to use the real resolved tier."
        }
      }
    },
    "keybindings": [
      {
        "command": "agi-workforce.chat",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "!terminalFocus && !agi-workforce.hasDiff"
      },
      {
        "command": "agi-workforce.explain",
        "key": "ctrl+shift+alt+e",
        "mac": "cmd+shift+alt+e",
        "when": "editorHasSelection"
      },
      {
        "command": "agi-workforce.agentMode",
        "key": "ctrl+shift+alt+g",
        "mac": "cmd+shift+alt+g"
      },
      {
        "command": "agi-workforce.askAboutCode",
        "key": "ctrl+shift+alt+a",
        "mac": "cmd+shift+alt+a",
        "when": "editorTextFocus"
      },
      {
        "command": "agi-workforce.explainError",
        "key": "ctrl+shift+alt+x",
        "mac": "cmd+shift+alt+x",
        "when": "editorTextFocus"
      },
      {
        "command": "agi-workforce.runCommand",
        "key": "ctrl+shift+alt+t",
        "mac": "cmd+shift+alt+t"
      },
      {
        "command": "agi-workforce.newConversation",
        "key": "ctrl+shift+alt+n",
        "mac": "cmd+shift+alt+n"
      },
      {
        "command": "agi-workforce.acceptCurrentDiff",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorTextFocus && agi-workforce.hasDiff"
      },
      {
        "command": "agi-workforce.rejectCurrentDiff",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorTextFocus && agi-workforce.hasDiff"
      },
      {
        "command": "agi-workforce.acceptDiff",
        "key": "ctrl+shift+enter",
        "mac": "cmd+shift+enter",
        "when": "editorTextFocus && agi-workforce.hasDiff"
      },
      {
        "command": "agi-workforce.rejectDiff",
        "key": "escape",
        "when": "editorTextFocus && agi-workforce.hasDiff"
      },
      {
        "command": "agi-workforce.acceptAllDiffsGlobal",
        "key": "ctrl+shift+alt+y",
        "mac": "cmd+shift+alt+y",
        "when": "agi-workforce.hasDiff"
      },
      {
        "command": "agi-workforce.rejectAllDiffsGlobal",
        "key": "ctrl+shift+alt+u",
        "mac": "cmd+shift+alt+u",
        "when": "agi-workforce.hasDiff"
      }
    ]
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production && node scripts/vsce-package.js package --no-dependencies",
    "lint": "eslint src --ext ts --cache --cache-strategy content --cache-location .cache/eslint",
    "test": "vitest run",
    "test:integration": "tsc -p tsconfig.test.json && node out/test/runTests.js",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf out",
    "prebuild": "pnpm run clean && pnpm run typecheck",
    "build": "pnpm run compile"
  },
  "dependencies": {
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.110.0",
    "@types/ws": "^8.18.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "rimraf": "^6.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
