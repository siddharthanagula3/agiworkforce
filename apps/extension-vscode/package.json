{
  "name": "agi-workforce",
  "displayName": "AGI Workforce",
  "description": "AI-powered coding assistant powered by AGI Workforce",
  "version": "0.1.0",
  "publisher": "agiworkforce",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agiworkforce/agiworkforce"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "ai",
    "llm",
    "chat",
    "copilot",
    "assistant",
    "coding",
    "agent",
    "gpt",
    "claude",
    "gemini"
  ],
  "activationEvents": [
    "onChatParticipant:agiworkforce.agi"
  ],
  "main": "./out/extension.js",
  "icon": "media/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "agi-workforce.chat",
        "title": "AGI Workforce: Open Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "agi-workforce.explain",
        "title": "AGI Workforce: Explain Selection",
        "icon": "$(info)"
      },
      {
        "command": "agi-workforce.fix",
        "title": "AGI Workforce: Fix Issue",
        "icon": "$(wrench)"
      },
      {
        "command": "agi-workforce.refactor",
        "title": "AGI Workforce: Refactor Code",
        "icon": "$(symbol-class)"
      },
      {
        "command": "agi-workforce.generateTests",
        "title": "AGI Workforce: Generate Tests",
        "icon": "$(beaker)"
      },
      {
        "command": "agi-workforce.setApiKey",
        "title": "AGI Workforce: Set API Key",
        "icon": "$(key)"
      },
      {
        "command": "agi-workforce.clearApiKey",
        "title": "AGI Workforce: Clear API Key",
        "icon": "$(trash)"
      },
      {
        "command": "agi-workforce.selectModel",
        "title": "AGI Workforce: Select Model",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "agi-workforce.openConversation",
        "title": "AGI Workforce: Open Conversation",
        "icon": "$(comment)"
      },
      {
        "command": "agi-workforce.deleteConversation",
        "title": "AGI Workforce: Delete Conversation",
        "icon": "$(trash)"
      },
      {
        "command": "agi-workforce.refreshConversations",
        "title": "AGI Workforce: Refresh Conversations",
        "icon": "$(refresh)"
      }
    ],
    "chatParticipants": [
      {
        "id": "agiworkforce.agi",
        "name": "agi",
        "fullName": "AGI Workforce",
        "description": "Model-agnostic AI assistant — use any LLM (GPT-4o, Claude, Gemini, and more)",
        "isSticky": true,
        "commands": [
          {
            "name": "explain",
            "description": "Explain the selected code or current file"
          },
          {
            "name": "fix",
            "description": "Find and fix bugs or issues in the selected code"
          },
          {
            "name": "refactor",
            "description": "Suggest refactoring improvements for the selected code"
          },
          {
            "name": "tests",
            "description": "Generate unit tests for the selected code"
          },
          {
            "name": "docs",
            "description": "Generate documentation comments for the selected code"
          },
          {
            "name": "model",
            "description": "Switch the active LLM model"
          }
        ],
        "disambiguation": [
          {
            "category": "coding",
            "description": "Questions about writing, understanding, debugging, or improving code",
            "examples": [
              "Explain this function to me",
              "Why is this code throwing an error?",
              "How can I optimize this algorithm?",
              "Write unit tests for this class"
            ]
          },
          {
            "category": "architecture",
            "description": "Questions about software design, architecture, and best practices",
            "examples": [
              "What design pattern should I use here?",
              "How should I structure this module?",
              "What are the tradeoffs between these approaches?"
            ]
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agi-workforce-sidebar",
          "title": "AGI Workforce",
          "icon": "media/icon-sidebar.svg"
        }
      ]
    },
    "views": {
      "agi-workforce-sidebar": [
        {
          "type": "webview",
          "id": "agi-workforce.sidebar",
          "name": "AGI Workforce",
          "contextualTitle": "AGI Workforce"
        },
        {
          "type": "tree",
          "id": "agi-workforce.conversations",
          "name": "History",
          "contextualTitle": "Conversation History"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "agi-workforce.openConversation",
          "when": "view == agi-workforce.conversations && viewItem == conversation",
          "group": "inline@1"
        },
        {
          "command": "agi-workforce.deleteConversation",
          "when": "view == agi-workforce.conversations && viewItem == conversation",
          "group": "inline@2"
        }
      ],
      "view/title": [
        {
          "command": "agi-workforce.refreshConversations",
          "when": "view == agi-workforce.conversations",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "agi-workforce.explain",
          "when": "editorHasSelection",
          "group": "agi-workforce@1"
        },
        {
          "command": "agi-workforce.fix",
          "when": "editorHasSelection",
          "group": "agi-workforce@2"
        },
        {
          "command": "agi-workforce.refactor",
          "when": "editorHasSelection",
          "group": "agi-workforce@3"
        },
        {
          "command": "agi-workforce.generateTests",
          "when": "editorHasSelection",
          "group": "agi-workforce@4"
        }
      ],
      "commandPalette": [
        {
          "command": "agi-workforce.explain",
          "when": "editorHasSelection"
        },
        {
          "command": "agi-workforce.fix",
          "when": "editorIsOpen"
        }
      ]
    },
    "configuration": {
      "title": "AGI Workforce",
      "properties": {
        "agiWorkforce.apiEndpoint": {
          "type": "string",
          "default": "https://agiworkforce.com/api/llm/v1",
          "description": "AGI Workforce API endpoint base URL"
        },
        "agiWorkforce.model": {
          "type": "string",
          "default": "auto-balanced",
          "description": "Default LLM model (e.g. auto-balanced, claude-sonnet-4.6, gpt-5.2, gemini-3-pro-preview)"
        },
        "agiWorkforce.streamingEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable streaming responses from AGI Workforce API"
        },
        "agiWorkforce.contextLines": {
          "type": "number",
          "default": 50,
          "minimum": 0,
          "maximum": 500,
          "description": "Number of surrounding lines to include as context"
        },
        "agiWorkforce.fallbackToVscodeLm": {
          "type": "boolean",
          "default": true,
          "description": "Fall back to VS Code built-in Language Model API if AGI Workforce API is unavailable"
        },
        "agiWorkforce.telemetryEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Send anonymous usage telemetry to help improve AGI Workforce"
        },
        "agiWorkforce.hoverEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Show AGI Workforce quick actions on hover over identifiers"
        },
        "agiWorkforce.autoApplyFixes": {
          "type": "boolean",
          "default": false,
          "description": "Automatically apply AI-suggested fixes without showing a diff"
        },
        "agiWorkforce.inlineCompletions.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable ghost-text inline completions (requires API key)"
        },
        "agiWorkforce.agent.planMode": {
          "type": "boolean",
          "default": false,
          "description": "Show a plan before executing agent tasks (requires confirmation)"
        },
        "agiWorkforce.mcp.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Model Context Protocol (MCP) tool integrations"
        },
        "agiWorkforce.desktopBridge.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Connect to AGI Workforce desktop app for extended agent capabilities"
        },
        "agiWorkforce.desktopBridge.port": {
          "type": "number",
          "default": 9000,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Local port for AGI Workforce desktop bridge connection"
        }
      }
    },
    "keybindings": [
      {
        "command": "agi-workforce.chat",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "!terminalFocus"
      },
      {
        "command": "agi-workforce.explain",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorHasSelection"
      }
    ]
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production && vsce package --no-dependencies",
    "lint": "eslint src --ext ts",
    "test": "echo 'vscode extension tests not yet configured'",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf out",
    "prebuild": "pnpm run clean && pnpm run typecheck",
    "build": "pnpm run compile"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "rimraf": "^6.0.0",
    "typescript": "^5.9.3"
  }
}
