# Source files (compiled to out/)
src/**
!out/**

# Config / build files
.vscode/**
.vscode-test/**
esbuild.js
tsconfig.json
.tsbuildinfo
.eslintrc*
eslint.config*
.editorconfig
.gitignore
.gitattributes
vitest.config.ts
scripts/**

# Node modules (esbuild bundles dependencies into out/extension.js)
node_modules/**

# Test output
coverage/**
*.test.ts
*.spec.ts

# Misc dev artifacts
out/**/*.map
*.log
*.tmp
.DS_Store
Thumbs.db
.cache/**

# pnpm / npm lockfiles (not needed in VSIX)
pnpm-lock.yaml
package-lock.json
yarn.lock

# Docs (not needed in VSIX)
COMPETITIVE_VSCODE_RESEARCH.md
competitive-research.md
