{
  "name": "agiworkforce",
  "version": "0.1.1",
  "private": true,
  "description": "AGI Workforce monorepo (Tauri + React + Rust)",
  "homepage": "https://agiworkforce.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/siddhartha/agiworkforce.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@9.15.3",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9.15.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [],
    "peerDependencyRules": {
      "ignoreMissing": []
    },
    "overrides": {
      "baseline-browser-mapping": "^2.9.11",
      "lodash-es": "^4.17.23",
      "diff": "^5.2.2",
      "qs": ">=6.14.2"
    }
  },
  "scripts": {
    "prepare": "husky install",
    "lint": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs --max-warnings=5 --ignore-pattern 'apps/extension/**'",
    "lint:extension": "eslint apps/extension --ext .ts,.tsx,.js,.cjs,.mjs --max-warnings=5",
    "lint:fix": "pnpm lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "cd apps/desktop && tsc --noEmit",
    "test": "pnpm -r test",
    "clean": "pnpm -r exec rm -rf dist node_modules && rm -rf node_modules",
    "clean:build": "pnpm -r exec rm -rf dist",
    "build": "pnpm build:all",
    "build:all": "pnpm -r --filter='!@agiworkforce/desktop' build",
    "build:desktop": "pnpm --filter @agiworkforce/desktop build",
    "build:docs": "pnpm --filter @agiworkforce/docs build",
    "dev:desktop": "pnpm --filter @agiworkforce/desktop dev",
    "dev:docs": "pnpm --filter @agiworkforce/docs start",
    "typecheck:all": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@playwright/test": "^1.58.0",
    "@types/node": "^25.1.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "baseline-browser-mapping": "^2.9.19",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "playwright": "^1.58.0",
    "prettier": "^3.8.1",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,cjs,mjs}": [
      "eslint --fix --ignore-pattern 'apps/extension/**'",
      "prettier --write"
    ],
    "**/*.{json,md,css,scss,html,yml,yaml}": [
      "prettier --write"
    ]
  }
}
