{
  "name": "agiworkforce",
  "version": "1.1.5",
  "private": true,
  "description": "AGI Workforce monorepo (Tauri + React + Rust)",
  "homepage": "https://agiworkforce.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/siddhartha/agiworkforce.git"
  },
  "license": "PROPRIETARY",
  "packageManager": "pnpm@9.15.3",
  "engines": {
    "node": "22",
    "pnpm": ">=9.15.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ],
    "peerDependencyRules": {
      "ignoreMissing": []
    },
    "overrides": {
      "baseline-browser-mapping": "^2.9.11",
      "lodash-es": "^4.17.23",
      "diff": "^5.2.2",
      "jsdom": "20.0.3",
      "qs": ">=6.14.2",
      "minimatch@3": ">=3.1.4",
      "minimatch@9": ">=9.0.7",
      "tar": ">=7.5.10",
      "rollup": ">=4.59.0",
      "serialize-javascript": ">=6.0.3",
      "uuid": "^13.0.0",
      "immer": "^11.1.4",
      "prismjs": ">=1.30.0"
    }
  },
  "scripts": {
    "prepare": "husky || true",
    "lint": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs --cache --cache-strategy content --cache-location .cache/eslint/root --max-warnings=0 --ignore-pattern 'apps/extension/**'",
    "lint:extension": "eslint apps/extension --ext .ts,.tsx,.js,.cjs,.mjs --cache --cache-strategy content --cache-location .cache/eslint/extension --max-warnings=0",
    "lint:fix": "pnpm lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm --filter @agiworkforce/desktop typecheck",
    "test": "pnpm -r test",
    "clean": "pnpm -r exec rm -rf dist node_modules && rm -rf node_modules",
    "clean:build": "pnpm -r exec rm -rf dist",
    "build": "pnpm build:all",
    "build:all": "pnpm -r --filter='!@agiworkforce/desktop' build",
    "build:desktop": "pnpm --filter @agiworkforce/desktop build",
    "build:docs": "pnpm --filter @agiworkforce/docs build",
    "dev:desktop": "pnpm --filter @agiworkforce/desktop dev",
    "dev:docs": "pnpm --filter @agiworkforce/docs start",
    "typecheck:all": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,cjs,mjs}": [
      "eslint --fix --ignore-pattern 'apps/extension/**'",
      "prettier --write"
    ],
    "**/*.{json,md,css,scss,html,yml,yaml}": [
      "prettier --write"
    ]
  }
}
