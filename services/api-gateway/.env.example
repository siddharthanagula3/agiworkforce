# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# P0-G (Wave 1, 2026-05-08): the gateway issues its own HS256 access tokens
# but mints per-request Supabase JWTs to drive RLS for user-scoped routes.
# Both of the keys below are in the Supabase project's "Settings → API" panel.
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
JWT_SECRET=your-jwt-secret

# Server
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000,tauri://localhost

# Signaling
SIGNALING_HTTP_URL=http://localhost:4000

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...
