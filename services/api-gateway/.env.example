# =============================================================================
# API Gateway — Environment Variables
# Copy this file to .env and fill in the values for local development.
# For production, set these as environment variables in your hosting provider.
# =============================================================================


# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------
JWT_SECRET=your-jwt-secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
PORT=3000
LOG_LEVEL=info
TRUST_PROXY=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
MCP_CONFIG_PATH=.mcp.json
WS_MAX_MESSAGE_SIZE=65536
WS_AUTH_TIMEOUT_MS=30000
SIGNALING_HTTP_URL=http://localhost:4000
