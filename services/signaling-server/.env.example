# Signaling Server Environment Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# REQUIRED: Supabase Configuration
# =============================================================================

# Supabase project URL (required)
# Get this from: Supabase Dashboard > Settings > API > Project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key (required, keep secret!)
# Get this from: Supabase Dashboard > Settings > API > service_role key
# WARNING: This key bypasses RLS - never expose it client-side
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# OPTIONAL: Server Configuration
# =============================================================================

# Server port (default: 4000)
# PORT takes precedence over SIGNALING_PORT
PORT=4000
# SIGNALING_PORT=4000

# Server host binding (default: 0.0.0.0)
# Use 127.0.0.1 for local-only access
SIGNALING_HOST=0.0.0.0

# WebSocket path (default: /ws)
SIGNALING_WS_PATH=/ws

# =============================================================================
# OPTIONAL: Public URLs
# =============================================================================

# Public HTTP URL for clients (default: http://{host}:{port})
# Set this when behind a reverse proxy or load balancer
# SIGNALING_HTTP_URL=https://signaling.yourdomain.com

# Public WebSocket URL for clients (default: derived from HTTP URL)
# Set this when behind a reverse proxy or load balancer
# SIGNALING_WS_URL=wss://signaling.yourdomain.com/ws

# =============================================================================
# OPTIONAL: Pairing Configuration
# =============================================================================

# Pairing code time-to-live in seconds (default: 300 = 5 minutes)
# Valid range: 30-900 seconds
SIGNALING_PAIRING_TTL=300

# =============================================================================
# OPTIONAL: CORS Configuration
# =============================================================================

# Comma-separated list of allowed origins for CORS
# Default: http://localhost:3000,http://localhost:3001,http://localhost:4000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:4000

# =============================================================================
# OPTIONAL: Security Configuration
# =============================================================================

# Admin API key for /metrics and /admin/* endpoints
# If not set, admin endpoints will return 503 and metrics will be public
# Generate a strong random key: openssl rand -hex 32
# ADMIN_API_KEY=your-secure-api-key-here

# Enable HSTS (HTTP Strict Transport Security)
# Only enable in production with HTTPS
# ENABLE_HSTS=true

# HSTS max-age in seconds (default: 31536000 = 1 year)
# HSTS_MAX_AGE=31536000

# Include subdomains in HSTS (default: true)
# HSTS_INCLUDE_SUBDOMAINS=true

# Enable HSTS preload (default: false)
# HSTS_PRELOAD=false

# =============================================================================
# OPTIONAL: WebSocket Rate Limiting
# =============================================================================

# Maximum WebSocket connections per IP per window (default: 10)
# WS_CONNECTION_LIMIT=10

# Maximum WebSocket messages per IP per window (default: 100)
# WS_MESSAGE_LIMIT=100

# Rate limit window duration in milliseconds (default: 60000 = 1 minute)
# WS_RATE_LIMIT_WINDOW_MS=60000

# Blacklist duration in milliseconds (default: 300000 = 5 minutes)
# WS_BLACKLIST_DURATION_MS=300000

# Number of violations before blacklisting (default: 5)
# WS_BLACKLIST_THRESHOLD=5

# =============================================================================
# OPTIONAL: Admin Authentication
# =============================================================================

# Maximum failed auth attempts before lockout (default: 10)
# MAX_AUTH_FAILURES=10

# Auth lockout duration in milliseconds (default: 900000 = 15 minutes)
# AUTH_LOCKOUT_DURATION_MS=900000

# Auth failure tracking window in milliseconds (default: 3600000 = 1 hour)
# AUTH_FAILURE_WINDOW_MS=3600000

# =============================================================================
# OPTIONAL: Logging
# =============================================================================

# Log level (default: info in production, debug in development)
# Options: trace, debug, info, warn, error, fatal, silent
# LOG_LEVEL=info

# Node environment (affects logging format and defaults)
# NODE_ENV=production
