# Dependencies
node_modules/
.pnpm-store/

# Build artifacts
dist/

# Development files
*.log
*.md
.env
.env.*
!.env.example

# Exclude base tsconfig (we use tsconfig.docker.json for standalone builds)
tsconfig.json

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# Git
.git/
.gitignore

# Docker files (prevent recursive build context)
Dockerfile*
docker-compose*.yml
.dockerignore

# Deployment configs (not needed in image)
railway.toml
fly.toml

# Test files
*.test.ts
*.spec.ts
__tests__/
coverage/

# OS files
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/
*.tmp
