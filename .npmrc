# pnpm settings
auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=true
audit-level=high

# Suppress engine warnings (Node version mismatches from external packages)
# This prevents warnings from Windsurf and other external tools
engine-strict=false

# Suppress warnings from packages outside the workspace
# This prevents warnings about resolutions field in external packages
warn-workspace-packages=false

# Allow warn-level output so pnpm audit results and peer dependency warnings remain visible
loglevel=warn
