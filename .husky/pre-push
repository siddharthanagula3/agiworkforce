echo "Running pre-push checks..."

# 1. Frontend Lint
echo "Checking frontend lints..."
pnpm lint || { echo "Frontend lint failed"; exit 1; }

# 2. Frontend Type Check
echo "Running type check..."
pnpm typecheck || { echo "Frontend type check failed"; exit 1; }

# 3. Rust Formatting
echo "Checking Rust formatting..."
(cd apps/desktop/src-tauri && cargo fmt --check) || { echo "Rust formatting failed"; exit 1; }

# 4. Rust Clippy (Lints)
echo "Checking Rust lints..."
(cd apps/desktop/src-tauri && cargo clippy -- -D warnings) || { echo "Rust clippy failed"; exit 1; }

# 5. Rust Tests
echo "Running Rust tests..."
(cd apps/desktop/src-tauri && cargo test) || { echo "Rust tests failed"; exit 1; }

# 6. Frontend Tests
echo "Running frontend tests..."
pnpm test || { echo "Frontend tests failed"; exit 1; }

echo "All checks passed! Pushing to remote..."
