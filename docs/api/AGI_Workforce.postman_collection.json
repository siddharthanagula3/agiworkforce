{
  "info": {
    "name": "AGI Workforce API",
    "_postman_id": "agi-workforce-api-v2",
    "description": "Complete API collection for AGI Workforce platform including authentication, LLM operations, chat, agents, memory, subscriptions, device management, media generation, scheduling, and more.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "2.0.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{bearer_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://agiworkforce.com/api",
      "type": "string"
    },
    {
      "key": "gateway_url",
      "value": "https://api.agiworkforce.com",
      "type": "string"
    },
    {
      "key": "bearer_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "device_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "link_code",
      "value": "",
      "type": "string"
    },
    {
      "key": "csrf_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "conversation_id",
      "value": "",
      "type": "string"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Auto-fetch CSRF token if not set",
          "if (!pm.collectionVariables.get('csrf_token')) {",
          "  pm.sendRequest({",
          "    url: pm.collectionVariables.get('base_url') + '/csrf',",
          "    method: 'GET'",
          "  }, function (err, res) {",
          "    if (!err && res.code === 200) {",
          "      var body = res.json();",
          "      pm.collectionVariables.set('csrf_token', body.token);",
          "    }",
          "  });",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Health check endpoint. No authentication required.\n\nChecks database, Stripe, and environment status.\n\nRate Limit: 30 requests/minute"
          }
        },
        {
          "name": "Voice Health",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/voice/health",
              "host": ["{{base_url}}"],
              "path": ["voice", "health"]
            },
            "description": "Voice transcription service health check."
          }
        }
      ]
    },
    {
      "name": "Auth & CSRF",
      "item": [
        {
          "name": "Get CSRF Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "pm.collectionVariables.set('csrf_token', response.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/csrf",
              "host": ["{{base_url}}"],
              "path": ["csrf"]
            },
            "description": "Get a CSRF token for state-changing requests.\n\nToken must be included in the x-csrf-token header for POST/PUT/DELETE requests.\n\nExpires in 1 hour."
          }
        },
        {
          "name": "Desktop Token Exchange",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/desktop-token",
              "host": ["{{base_url}}"],
              "path": ["auth", "desktop-token"]
            },
            "description": "Exchange credentials for a desktop authentication token."
          }
        },
        {
          "name": "SSO Check",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/sso-check?email=user@example.com",
              "host": ["{{base_url}}"],
              "path": ["auth", "sso-check"],
              "query": [
                {
                  "key": "email",
                  "value": "user@example.com"
                }
              ]
            },
            "description": "Check if SSO is available for an email domain."
          }
        }
      ]
    },
