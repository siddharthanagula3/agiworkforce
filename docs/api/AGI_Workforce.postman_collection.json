    {
      "name": "Device Management",
      "item": [
        {
          "name": "Generate Link Code",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "pm.collectionVariables.set('link_code', response.link_code);",
                  "pm.collectionVariables.set('device_id', response.device_id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-csrf-token",
                "value": "{{csrf_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"{{$guid}}\",\n  \"device_name\": \"Postman Test Device\",\n  \"device_type\": \"desktop\",\n  \"device_fingerprint\": \"{{$guid}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/device/link",
              "host": ["{{base_url}}"],
              "path": ["device", "link"]
            },
            "description": "Generate a device linking code with QR code.\n\nRequires authentication. Code expires in 15 minutes.\n\nRate Limit: 10 requests/minute"
          }
        },
        {
          "name": "Poll Device Status",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"{{device_id}}\",\n  \"device_fingerprint\": \"{{$guid}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/device/poll",
              "host": ["{{base_url}}"],
              "path": ["device", "poll"]
            },
            "description": "Poll device authorization status.\n\ndevice_fingerprint is required for new sessions.\n\nRecommended: Poll every 2-3 seconds.\n\nRate Limit: 10 requests/second"
          }
        },
        {
          "name": "Approve Device",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"{{link_code}}\",\n  \"approved\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/device/approve",
              "host": ["{{base_url}}"],
              "path": ["device", "approve"]
            },
            "description": "Approve a device linking request (user authorization).\n\nRate Limit: 10 requests/minute"
          }
        }
      ]
    },
