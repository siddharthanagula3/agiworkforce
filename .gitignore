# ==========================================
# AGI Workforce - Complete .gitignore
# ==========================================

# --- Node.js / NPM / PNPM ---
node_modules/
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
*.tsbuildinfo
.npm
.eslintcache
.node_repl_history
*.tgz
*.backup

# --- Logs ---
logs/
*.log
report.*.json

# --- Internal/local artifacts (root-level only) ---
/artifacts/

# --- Runtime data ---
pids/
*.pid
*.seed
*.pid.lock

# --- Coverage directories ---
coverage/
*.lcov
.nyc_output/
lib-cov/

# --- Build artifacts ---
dist/
dist-ssr/
build/
out/
.next/
.nuxt/
.cache/
.parcel-cache/
.vite/
*.local
*.tsbuildinfo

# --- Distribution/Downloads ---
**/public/downloads/

# --- Vite specific ---
vite.config.*.timestamp-*

# --- Tauri specific ---
apps/desktop/src-tauri/target/
apps/desktop/src-tauri/gen/
apps/desktop/src-tauri/WixTools/
apps/desktop/src-tauri/tauri-info.json

# --- Rust / Cargo ---
**/target/
**/*.rs.bk
**/*.rlib
*.rlib
Cargo.lock
# Allow Cargo.lock for applications and workspace root
!apps/**/Cargo.lock
!/Cargo.lock

# --- Database files ---
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# --- Testing ---
.vitest/
playwright-report/
test-results/
playwright/.cache/

# --- OS specific ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- IDE / Editor ---
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.code-workspace

# --- Environment variables ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
.env.*.local
!.env.example

# --- Temporary files ---
*.tmp
*.temp
*.bak
*.old
*.orig
*.rej
.temp/
.tmp/

# --- Application data ---
apps/desktop/src-tauri/agiworkforce.db
apps/desktop/src-tauri/test.db
agiworkforce.db*

# --- Generated files ---
package-lock.json
yarn.lock

# --- Debug files ---
debug/
*.pdb

# --- Certificates and keys ---
*.pem
*.key
*.crt
*.p12
*.pfx
# Test fixtures — these are self-signed certs used only by unit
# tests for the custom-CA loader. Safe to commit; do not contain
# any production secrets.
!crates/agiworkforce-client/tests/fixtures/*.pem
!crates/agiworkforce-client/tests/fixtures/*.key

# --- Tauri update signing keys (never commit private keys) ---
apps/desktop/src-tauri/tauri-signing
apps/desktop/src-tauri/tauri-signing.pub

# --- MCP Configuration (contains sensitive credentials) ---
.mcp.json

# --- Application cache (root-level only) ---
.cache/
/cache/

# --- Playwright browsers ---
ms-playwright/

# --- Turbo ---
.turbo/

# --- Vercel ---
.vercel

# --- Sentry ---
.sentryclirc
.env*.local

# --- Build outputs ---
*.dmg
*.exe
*.AppImage
*.deb
*.rpm
*.msi

# --- Agent/AI temp files ---
.agent/
.claude/

# --- Business / personal data ---
leads/

# --- Supabase temp files ---
**/.temp/
.worktrees/
.code-review-graph/
dist-web
# Build artifacts (Vite SPA output)
apps/web/public/chat

# Claude Code local files
CLAUDE.local.md
.claude/settings.local.json
.claude/*.local.*
